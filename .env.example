# Generate with:
# node --input-type=module -e 'import argon2 from "argon2"; console.log(await argon2.hash(process.argv[1], { type: argon2.argon2id }))' 'choose-a-password'
# Keep the generated value inside single quotes so its $ characters stay literal.
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=''

# Generate with: openssl rand -base64 48
JWT_SECRET=

# Generate with: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=

# Local Compose example. Production must use the exact public HTTPS origin.
ALLOWED_ORIGIN=http://localhost:8080

JWT_EXPIRES_IN_SECONDS=3600
SSH_CONNECT_TIMEOUT_MS=10000
